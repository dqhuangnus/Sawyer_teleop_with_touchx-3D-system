<?xml version="1.0"?>
<!--
  TouchX -> Sawyer teleop WITH integrated data collection (single command).

  Brings up: Touch X driver (omni_state) + robot_state_publisher + RViz +
  the teleop node, which also records tactile-ACT episodes.

  Prerequisites:
    1. Sawyer powered + reachable, intera.sh sourced, robot enabled
    2. TouchX USB connected
    3. For tactile: start the XELA server first, in the container (see README
       for the exact xela_server command and its port/ip flags).

  Usage:
    roslaunch touchx_sawyer_teleop touchx_teleop.launch

  Keys (in this terminal):  h=home  r=record  f=finish+save  d=discard
  Episodes are written to save_dir below (mount it out to keep them).
-->
<launch>

  <!-- TouchX haptic driver -->
  <include file="$(find omni_common)/launch/omni_state.launch">
    <arg name="publish_rate" value="50"/>
  </include>

  <!-- URDF (Sawyer + Robotiq 2F-85) -->
  <param name="robot_description"
         command="$(find xacro)/xacro
                  $(find touchx_sawyer_teleop)/urdf/sawyer_with_robotiq85.urdf.xacro
                  gazebo:=false"/>

  <!-- robot_state_publisher: /joint_states -> TF (node publishes /joint_states) -->
  <node name="robot_state_publisher"
        pkg="robot_state_publisher"
        type="robot_state_publisher"
        output="screen"/>

  <!-- RViz -->
  <node name="rviz" pkg="rviz" type="rviz"
        args="-d $(find touchx_sawyer_teleop)/rviz/teleop_viz.rviz"/>

  <!-- Teleop + recorder -->
  <node name="test_touchx_teleop_viz"
        pkg="touchx_sawyer_teleop"
        type="test_touchx_teleop_viz.py"
        output="screen">
    <!-- teleop -->
    <param name="position_scale" value="1.5"/>
    <param name="control_rate"   value="50.0"/>
    <param name="smooth_hz"      value="5.0"/>
    <param name="roll_scale"     value="0.4"/>
    <param name="pitch_scale"    value="0.4"/>
    <param name="yaw_scale"      value="0.8"/>
    <rosparam param="workspace_centre">[0.70, 0.00, 0.20]</rosparam>
    <rosparam param="home_config">[0.1001, -1.0716, -0.3894, 1.7071, 0.1720, 1.0877, 2.8392]</rosparam>

    <!-- data collection -->
    <param name="record_enabled"   value="true"/>
    <param name="record_rate"      value="20.0"/>
    <param name="save_dir"         value="/root/collected_data"/>
    <param name="xela_ws_url"      value="ws://localhost:5000"/>
    <param name="camera_scale"     value="0.5"/>
    <param name="camera_binning"   value="2"/>
    <param name="camera_fps"       value="10"/>
    <param name="record_realsense" value="false"/>
    <rosparam param="camera_ips">{image_left: '192.168.1.130', image_right: '192.168.1.120', image_top: '192.168.1.100'}</rosparam>
  </node>

</launch>
